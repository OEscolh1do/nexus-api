generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model TechnicalDesign {
  id           String        @id @default(cuid())
  tenantId     String        @default("default-tenant-001")
  iacaLeadId   String?
  name         String
  status       String        @default("DRAFT")
  designData   Json?
  notes        String?       @db.Text
  createdBy    String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  latitude     Float?
  longitude    Float?
  pvArrays     PVArray[]
  roofSections RoofSection[]
  simulations  Simulation[]

  @@index([tenantId])
  @@index([iacaLeadId])
  @@index([createdBy])
  @@index([status])
}

model RoofSection {
  id                String          @id @default(cuid())
  technicalDesignId String
  polygonGeoJson    Json
  azimuth           Float
  tilt              Float
  area              Float
  shadingFactor     Float           @default(1)
  label             String?
  pvArrays          PVArray[]
  technicalDesign   TechnicalDesign @relation(fields: [technicalDesignId], references: [id], onDelete: Cascade)

  @@index([technicalDesignId])
}

model PVArray {
  id                String          @id @default(cuid())
  technicalDesignId String
  roofSectionId     String?
  moduleModel       String
  modulePower       Float
  moduleCount       Int
  stringConfig      Json?
  inverterModel     String?
  inverterPower     Float?
  cableSectionMm2   Float?
  estimatedGenKwh   Float?
  roofSection       RoofSection?    @relation(fields: [roofSectionId], references: [id])
  technicalDesign   TechnicalDesign @relation(fields: [technicalDesignId], references: [id], onDelete: Cascade)

  @@index([technicalDesignId])
  @@index([roofSectionId])
}

model Simulation {
  id                String          @id @default(cuid())
  technicalDesignId String
  type              String
  inputParams       Json
  resultData        Json
  executedAt        DateTime        @default(now())
  technicalDesign   TechnicalDesign @relation(fields: [technicalDesignId], references: [id], onDelete: Cascade)

  @@index([technicalDesignId])
  @@index([type])
}

model ModuleCatalog {
  id                String  @id @default(cuid())
  manufacturer      String
  model             String  @unique
  powerWp           Float
  efficiency        Float?
  dimensions        String?
  weight            Float?
  datasheet         String?
  imageUrl          String?
  unifilarSymbolRef String?
  isActive          Boolean @default(true)
  
  // -- Engineering PV Specs (v3.7) --
  bifacial          Boolean @default(false)
  bifacialityFactor Float?
  noct              Float?
  tempCoeffVoc      Float?
  tempCoeffPmax     Float?
  cellSizeClass     String?
  degradacaoAnual   Decimal @default(0.005) @db.Decimal(5,4)
  
  electricalData    Json?

  @@index([manufacturer])
}

model InverterCatalog {
  id                String  @id @default(cuid())
  manufacturer      String
  model             String  @unique
  nominalPowerW     Float
  maxInputV         Float?
  mpptCount         Int?
  efficiency        Float?
  datasheet         String?
  imageUrl          String?
  unifilarSymbolRef String?
  isActive          Boolean @default(true)
  
  // -- Engineering PV Specs (v3.7) --
  Voc_max_hardware  Float?
  Isc_max_hardware  Float?
  coolingType       String? @default("passive")
  afci              Boolean @default(true)
  rsd               Boolean @default(false)
  portaria515Compliant Boolean @default(false)

  electricalData    Json?

  @@index([manufacturer])
}
