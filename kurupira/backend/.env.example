# =============================================================
# Kurupira Backend — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais.
# =============================================================

# --- Banco de Dados (MySQL / TiDB) ---
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/db_kurupira"
# Necessário apenas para `prisma migrate dev` (requer CREATE DATABASE)
# Não é usado em produção — deixe vazio ou omita se usar `db push`
SHADOW_DATABASE_URL="mysql://ADMIN_USER:ADMIN_PASSWORD@HOST:3306/db_kurupira_shadow"

# --- Conexão Read-Only com Sumaúma ---
# Usada pelo middleware de Auth para resolver tenant e role
DATABASE_URL_SUMAUMA_RO="mysql://user_admin:password@HOST:3306/db_sumauma"

# --- Autenticação ---
# Chave HS256 para tokens locais (dev/testes sem Logto)
# Em produção: mantenha em secrets manager e use apenas RS256/Logto
JWT_SECRET="troque_para_um_segredo_forte_em_producao"

# --- Logto (IAM) ---
LOGTO_ENDPOINT=https://SEU_TENANT.logto.app
LOGTO_JWKS_URI=https://SEU_TENANT.logto.app/oidc/jwks
# URI do API Resource cadastrado no Logto (usado como audience na validação)
LOGTO_M2M_RESOURCE=https://api.ywara.com.br

# --- M2M Legado (deprecado — remover após migração Logto M2M confirmada) ---
# M2M_SERVICE_TOKEN="token_legado"

# --- Serviços Internos ---
IACA_INTERNAL_URL=http://iaca-backend:3001

# --- Servidor ---
PORT=3002
NODE_ENV=development
# Ativar CORS estrito em staging sem NODE_ENV=production:
# CORS_STRICT=true
