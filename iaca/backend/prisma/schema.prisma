generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// =============================================================
// DOMÍNIO DE NEGÓCIO (Iaçã ERP - Plugin Mode)
// Este módulo não gerencia Identidade ou Tenancy. 
// Ele consome tenantId e userId validados pela Fundação Ywara.
// =============================================================

model OrgUnit {
  id               String            @id @default(cuid())
  name             String
  type             String
  parentId         String?
  config           String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @default(now()) @updatedAt
  navigationGroups NavigationGroup[]
  parent           OrgUnit?          @relation("OrgHierarchy", fields: [parentId], references: [id])
  children         OrgUnit[]         @relation("OrgHierarchy")
  pipelines        Pipeline[]
  Program          Program[]
  WorkflowRule     WorkflowRule[]

  @@index([parentId])
}

// O modelo User no Iaçã foi removido. 
// Relacionamentos agora usam userId (String) referenciando a Fundação.

model Project {
  id                 String    @id @default(cuid())
  strategyId         String?
  managerId          String?   // Referência externa ao User da Fundação
  title              String
  description        String?
  progressPercentage Float     @default(0)
  status             String    @default("PLANEJAMENTO")
  type               String    @default("GENERIC")
  details            String?
  quoteId            String?
  startDate          DateTime?
  endDate            DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @default(now()) @updatedAt
  tenantId           String    @default("default-tenant-001")
  clientId           String?   // Referência externa ao User da Fundação

  tasks    OperationalTask[]
  strategy Strategy?         @relation(fields: [strategyId], references: [id])
  risks    Risk[]
  Budget   Budget?
  Contract Contract[]

  @@index([tenantId])
  @@index([managerId])
  @@index([strategyId])
  @@index([clientId])
}

model OperationalTask {
  id                String    @id @default(cuid())
  projectId         String?
  title             String
  description       String?
  status            String    @default("BACKLOG")
  assignedTo        String?   // Referência externa ao User da Fundação
  completionPercent Float     @default(0)
  isMilestone       Boolean   @default(false)
  startDate         DateTime?
  endDate           DateTime?
  dueDate           DateTime?
  versionId         Int       @default(1)
  isRecurring       Boolean   @default(false)
  recurrencePattern String?
  nextRunAt         DateTime?
  parentTemplateId  String?
  isTemplate        Boolean   @default(false)
  lastSpawnedAt     DateTime?
  tags              String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt
  tenantId          String    @default("default-tenant-001")

  plannedValue Float @default(0)
  earnedValue  Float @default(0)
  actualCost   Float @default(0)

  checklists    Checklist[]
  project       Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  predecessors  TaskDependency[] @relation("TaskPredecessor")
  successors    TaskDependency[] @relation("TaskSuccessor")
  PurchaseOrder PurchaseOrder[]
  dailyReports  DailyReport[]

  @@index([tenantId])
  @@index([assignedTo])
  @@index([projectId])
}

model Strategy {
  id          String    @id @default(cuid())
  code        String    @unique
  title       String
  description String?
  colorCode   String    @default("#3B82F6")
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean   @default(true)
  type        String    @default("PILLAR")
  parentId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  tenantId    String    @default("default-tenant-001")
  ownerId     String?   // Referência externa ao User da Fundação

  keyResults KeyResult[]
  projects   Project[]
  risks      Risk[]
  parent     Strategy?   @relation("StrategyHierarchy", fields: [parentId], references: [id])
  children   Strategy[]  @relation("StrategyHierarchy")

  @@index([tenantId])
  @@index([parentId])
  @@index([ownerId])
}

model KeyResult {
  id            String   @id @default(cuid())
  strategyId    String
  title         String
  targetValue   Float
  currentValue  Float    @default(0)
  unit          String   @default("%")
  perspective   String?
  indicatorType String?
  frequency     String?
  lastUpdatedAt DateTime @default(now())
  ownerId       String?  // Referência externa ao User da Fundação

  strategy Strategy           @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  checkIns KeyResultCheckIn[]

  @@index([strategyId])
  @@index([ownerId])
}

model KeyResultCheckIn {
  id            String   @id @default(cuid())
  keyResultId   String
  tenantId      String   @default("default-tenant-001")
  userId        String   // Referência externa ao User da Fundação
  previousValue Float
  newValue      Float
  comment       String?  @db.Text
  checkInDate   DateTime @default(now())
  createdAt     DateTime @default(now())

  keyResult KeyResult @relation(fields: [keyResultId], references: [id], onDelete: Cascade)

  @@index([keyResultId])
  @@index([tenantId])
  @@index([userId])
}

model Risk {
  id          String    @id @default(cuid())
  title       String
  description String?
  probability String
  impact      String
  mitigation  String?
  status      String    @default("OPEN")
  strategyId  String?
  projectId   String?
  createdAt   DateTime  @default(now())
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  strategy    Strategy? @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([strategyId])
}

model TaskDependency {
  id            String          @id @default(cuid())
  predecessorId String
  successorId   String
  type          String          @default("FINISH_TO_START")
  predecessor   OperationalTask @relation("TaskPredecessor", fields: [predecessorId], references: [id], onDelete: Cascade)
  successor     OperationalTask @relation("TaskSuccessor", fields: [successorId], references: [id], onDelete: Cascade)

  @@unique([predecessorId, successorId])
  @@index([successorId])
}

model Checklist {
  id        String          @id @default(cuid())
  taskId    String
  title     String
  createdAt DateTime        @default(now())
  task      OperationalTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  items     ChecklistItem[]

  @@index([taskId])
}

model ChecklistItem {
  id          String    @id @default(cuid())
  checklistId String
  title       String
  isCompleted Boolean   @default(false)
  createdAt   DateTime  @default(now())
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId])
}

model Pipeline {
  id        String   @id @default(cuid())
  name      String
  type      String
  orgUnitId String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  orgUnit   OrgUnit  @relation(fields: [orgUnitId], references: [id], onDelete: Cascade)
  stages    Stage[]

  @@index([orgUnitId])
}

model Stage {
  id         String   @id @default(cuid())
  pipelineId String
  name       String
  order      Int
  createdAt  DateTime @default(now())
  color      String   @default("bg-slate-500")
  helpText   String?
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@index([pipelineId])
}

model Event {
  id          String     @id @default(cuid())
  title       String
  description String?
  type        String
  location    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @default(now()) @updatedAt
  date        DateTime
}

model Lead {
  id               String      @id @default(cuid())
  name             String
  email            String?
  phone            String
  status           String      @default("NEW")
  source           LeadSource?
  notes            String?
  ownerId          String?     // Referência externa ao User da Fundação
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @default(now()) @updatedAt
  academyOrigin    String?
  city             String?
  engagementScore  Int         @default(0)
  missionId        String?
  state            String?
  technicalProfile String?
  energyBillUrl    String?
  academyScore     Int?
  tenantId         String      @default("default-tenant-001")

  mission      Mission?          @relation(fields: [missionId], references: [id])
  interactions LeadInteraction[]
  Opportunity  Opportunity[]

  @@index([tenantId])
  @@index([ownerId])
  @@index([missionId])
}

model Mission {
  id            String        @id @default(cuid())
  region        String
  startDate     DateTime
  endDate       DateTime
  status        MissionStatus @default(PLANNING)
  stats         String?
  coordinatorId String?       // Referência externa ao User da Fundação
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  name          String
  regionPolygon String?
  tenantId      String        @default("default-tenant-001")

  leads         Lead[]
  opportunities Opportunity[]

  @@index([tenantId])
  @@index([coordinatorId])
}

model Opportunity {
  id                  String            @id @default(cuid())
  title               String
  leadId              String
  missionId           String?
  status              OpportunityStatus @default(LEAD_QUALIFICATION)
  estimatedValue      Decimal
  probability         Float             @default(0)
  technicalProposalId String?           @unique
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  tenantId            String

  lead              Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  mission           Mission?           @relation(fields: [missionId], references: [id])
  technicalProposal TechnicalProposal? @relation(fields: [technicalProposalId], references: [id])

  @@index([tenantId])
  @@index([leadId])
  @@index([missionId])
}

model TechnicalProposal {
  id                   String   @id @default(cuid())
  kitData              String
  consumptionAvg       Float
  infrastructurePhotos String
  paybackData          String
  validatedByEng       Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  tenantId             String

  opportunity Opportunity?

  @@index([tenantId])
}

model LeadInteraction {
  id        String   @id @default(cuid())
  leadId    String
  type      String
  content   String
  authorId  String   // Referência externa ao User da Fundação
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model HRLeave {
  id          String   @id @default(cuid())
  type        String
  startDate   DateTime
  endDate     DateTime
  status      String   @default("PENDENTE")
  reason      String?
  description String?
  destination String?
  requesterId String   // Referência externa ao User da Fundação
  approverId  String?  // Referência externa ao User da Fundação
  createdAt   DateTime @default(now())

  @@index([approverId])
  @@index([requesterId])
}

model Asset {
  id           String   @id @default(cuid())
  name         String
  type         String
  status       String   @default("AVAILABLE")
  serialNumber String?
  location     String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now())
}

model Program {
  id          String   @id @default(cuid())
  name        String
  description String?
  orgUnitId   String
  config      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
  OrgUnit     OrgUnit  @relation(fields: [orgUnitId], references: [id], onDelete: Cascade)

  @@index([orgUnitId])
}

model WorkflowRule {
  id        String   @id @default(cuid())
  orgUnitId String
  name      String
  condition String
  action    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  OrgUnit   OrgUnit  @relation(fields: [orgUnitId], references: [id], onDelete: Cascade)

  @@index([orgUnitId])
}

model NavigationGroup {
  id        String           @id @default(cuid())
  orgUnitId String
  module    String
  title     String
  order     Int              @default(0)
  isVisible Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  orgUnit   OrgUnit          @relation(fields: [orgUnitId], references: [id], onDelete: Cascade)
  items     NavigationItem[]

  @@index([orgUnitId, module])
}

model NavigationItem {
  id            String          @id @default(cuid())
  groupId       String
  label         String
  path          String
  icon          String
  order         Int             @default(0)
  isVisible     Boolean         @default(true)
  requiredRoles String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  group         NavigationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

model Budget {
  id           String   @id @default(cuid())
  projectId    String   @unique
  totalPlanned Float    @default(0)
  totalSpent   Float    @default(0)
  currency     String   @default("BRL")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  costCenters CostCenter[]
}

model CostCenter {
  id              String   @id @default(cuid())
  budgetId        String
  name            String
  code            String
  allocatedAmount Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  budget       Budget        @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([budgetId])
}

model Transaction {
  id           String          @id @default(cuid())
  costCenterId String
  amount       Float
  type         TransactionType
  description  String?
  date         DateTime        @default(now())
  createdAt    DateTime        @default(now())

  costCenter CostCenter @relation(fields: [costCenterId], references: [id], onDelete: Cascade)

  @@index([costCenterId])
}

model Vendor {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  cnpj         String?  @unique
  contactEmail String?
  contactPhone String?
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contracts      Contract[]
  purchaseOrders PurchaseOrder[]
  invoices       Invoice[]
  dailyReports   DailyReport[]

  @@index([tenantId])
}

model Contract {
  id        String    @id @default(cuid())
  projectId String
  vendorId  String
  title     String
  value     Float
  startDate DateTime?
  endDate   DateTime?
  status    String    @default("DRAFT")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendor   Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@index([projectId])
  @@index([vendorId])
}

model Material {
  id           String   @id @default(cuid())
  name         String
  code         String   @unique
  category     String?
  unit         String   @default("UN")
  unitCost     Float    @default(0)
  leadTimeDays Int      @default(15)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
}

model PurchaseOrder {
  id           String    @id @default(cuid())
  vendorId     String
  materialId   String
  taskId       String?
  quantity     Float
  unitPrice    Float
  totalPrice   Float
  expectedDate DateTime?
  status       String    @default("DRAFT")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  vendor   Vendor           @relation(fields: [vendorId], references: [id])
  material Material         @relation(fields: [materialId], references: [id])
  task     OperationalTask? @relation(fields: [taskId], references: [id])

  @@index([vendorId])
  @@index([materialId])
  @@index([taskId])
}

model ApprovalGate {
  id            String    @id @default(cuid())
  tenantId      String    @default("default-tenant-001")
  resourceType  String
  resourceId    String
  requiredRole  String
  status        String    @default("PENDING")
  requestedById String    // Referência externa ao User da Fundação
  approvedById  String?   // Referência externa ao User da Fundação
  justification String?   @db.Text
  deadlineAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId])
  @@index([resourceId])
  @@index([status])
}

model Invoice {
  id         String    @id @default(cuid())
  contractId String
  vendorId   String
  amount     Float
  status     String    @default("SUBMITTED")
  dueDate    DateTime?
  reference  String?
  fileUrl    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  contract Contract @relation(fields: [contractId], references: [id])
  vendor   Vendor   @relation(fields: [vendorId], references: [id])
}

model DailyReport {
  id        String   @id @default(cuid())
  taskId    String
  vendorId  String
  content   String   @db.Text
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  task   OperationalTask @relation(fields: [taskId], references: [id])
  vendor Vendor          @relation(fields: [vendorId], references: [id])

  @@index([taskId])
  @@index([vendorId])
}

model LedgerEntry {
  id        String   @id @default(cuid())
  tenantId  String
  amount    Float
  type      String
  category  String
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([tenantId])
}

enum MissionStatus {
  PLANNING
  ACTIVE
  COMPLETED
}

enum LeadSource {
  ORGANIC
  REFERRAL
  PAID_MEDIA
  ACADEMY
  OUTBOUND
}

enum OpportunityStatus {
  LEAD_QUALIFICATION
  VISIT_SCHEDULED
  TECHNICAL_VISIT_DONE
  PROPOSAL_GENERATED
  NEGOTIATION
  CONTRACT_SENT
  CLOSED_WON
  CLOSED_LOST
}

enum TenantType {
  MASTER
  SUB_TENANT
}

enum TransactionType {
  PLANNED
  ACTUAL
}
