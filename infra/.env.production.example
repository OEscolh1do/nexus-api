# =============================================================
# Neonorte Ywara — Variáveis de Produção
# Salvar como .env na raiz do projeto (/srv/ywara/.env)
# O docker-compose.yml lerá este arquivo automaticamente.
# NUNCA commitar este arquivo no git.
# =============================================================

# --- Banco de Dados MySQL ---
MYSQL_ROOT_PASSWORD=SUA_SENHA_ROOT_FORTE_AQUI

# Banco Iaçã
DB_IACA_USER=user_iaca
DB_IACA_PASSWORD=SUA_SENHA_IACA_AQUI

# Banco Kurupira
DB_KURUPIRA_USER=user_kurupira
DB_KURUPIRA_PASSWORD=SUA_SENHA_KURUPIRA_AQUI

# Banco Sumauma
DB_SUMAUMA_USER=user_sumauma
DB_SUMAUMA_PASSWORD=SUA_SENHA_SUMAUMA_AQUI

# Usuário admin read-only (cross-database)
DB_ADMIN_USER=user_admin
DB_ADMIN_PASSWORD=SUA_SENHA_ADMIN_AQUI

# --- JWT ---
# Gere com: openssl rand -base64 64
JWT_SECRET=GERE_UM_SEGREDO_FORTE_AQUI

# --- M2M Token entre serviços ---
# Gere com: openssl rand -hex 32
M2M_SERVICE_TOKEN=GERE_UM_TOKEN_FORTE_AQUI

# --- Logto (IAM) ---
LOGTO_ENDPOINT=https://214fzz.logto.app
LOGTO_JWKS_URI=https://214fzz.logto.app/oidc/jwks

# M2M Client (Sumauma → Logto Management API)
LOGTO_M2M_CLIENT_ID=SEU_CLIENT_ID_M2M_AQUI
LOGTO_M2M_CLIENT_SECRET=SEU_CLIENT_SECRET_M2M_AQUI
# URI do API Resource registrado no Logto Console (ex: https://api.ywara.com.br)
LOGTO_M2M_RESOURCE=SEU_API_RESOURCE_URI_AQUI

# --- URLs dos Frontends (para CORS) ---
KURUPIRA_FRONTEND_URL=https://kurupira.neonorte-ywara.tech
ADMIN_FRONTEND_URL=https://admin.neonorte-ywara.tech
