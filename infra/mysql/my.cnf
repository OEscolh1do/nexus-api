[mysqld]
# Otimização para VPS de baixa RAM (2GB total)
# Aloca ~256MB para o buffer pool, o que é suficiente para o volume de dados inicial do Ywara
innodb_buffer_pool_size = 256M
innodb_log_file_size = 64M
innodb_flush_method = O_DIRECT
innodb_flush_log_at_trx_commit = 2

# Limite de conexões para evitar spikes de memória
max_connections = 50
key_buffer_size = 16M
tmp_table_size = 16M
max_heap_table_size = 16M

# Desabilitar performance_schema se a RAM estiver muito crítica (economiza ~100MB-200MB)
performance_schema = OFF
