# =============================================================
# Sumauma Admin BFF — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais.
# =============================================================

# --- Servidor ---
PORT=3003
NODE_ENV=development

# --- Autenticação ---
# Chave HS256 para tokens locais (dev/testes sem Logto)
# Em produção: mantenha em secrets manager e use apenas RS256/Logto
JWT_SECRET="troque_para_um_segredo_forte_em_producao"

# --- M2M Legado (deprecado — remover após migração Logto M2M confirmada) ---
# M2M_SERVICE_TOKEN="token_legado"

# --- URLs Internas dos Serviços ---
IACA_INTERNAL_URL=http://iaca-backend:3001
KURUPIRA_INTERNAL_URL=http://kurupira-backend:3005

# --- Banco de Dados (Sumauma — escrita) ---
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/db_sumauma"

# --- Bancos de Dados (Read-Only — leitura direta nos serviços irmãos) ---
DATABASE_URL_IACA_RO="mysql://USER_RO:PASSWORD@HOST:3306/db_iaca"
DATABASE_URL_KURUPIRA_RO="mysql://USER_RO:PASSWORD@HOST:3306/db_kurupira"

# --- Shadow Database (para prisma migrate dev — não necessário em produção) ---
# SHADOW_DATABASE_URL="mysql://ADMIN_USER:ADMIN_PASSWORD@HOST:3306/db_sumauma_shadow"

# --- CORS ---
ADMIN_FRONTEND_URL=http://localhost:5175

# --- Logto (IAM) ---
LOGTO_ENDPOINT=https://SEU_TENANT.logto.app
LOGTO_JWKS_URI=https://SEU_TENANT.logto.app/oidc/jwks

# --- Credenciais M2M OAuth2 (Logto Console → Applications → Machine-to-Machine) ---
# ATENÇÃO: CLIENT_SECRET deve ser armazenado em secrets manager em produção
LOGTO_M2M_CLIENT_ID=SEU_CLIENT_ID
LOGTO_M2M_CLIENT_SECRET=SEU_CLIENT_SECRET

# --- API Resource e Scopes ---
# Deve coincidir com o API Resource registrado no Logto Console
LOGTO_M2M_RESOURCE=https://api.ywara.com.br
LOGTO_M2M_SCOPE=kurupira:catalog:read kurupira:catalog:write kurupira:catalog:delete

# --- Referência (usado no frontend Sumauma) ---
# LOGTO_APP_ID=SEU_APP_ID
